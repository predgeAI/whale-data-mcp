# The operator's OWN funded buyer wallet key. Defaults to Base MAINNET (the live
# Predge API is mainnet-only), so this spends REAL USDC — a few dollars is plenty
# (the facilitator pays gas, no ETH needed). Every call is capped by MAX_PRICE_USD.
# Use a dedicated, low-balance wallet. NEVER commit this key.
BUYER_PRIVATE_KEY=0x...

# Defaults (override only if needed)
# X402_NETWORK=base                    # mainnet (real USDC). "base-sepolia" needs a testnet deployment via PREDGE_BASE_URL
# PREDGE_BASE_URL=https://x402-api-production-266e.up.railway.app
# MAX_PRICE_USD=0.05                    # refuse any call priced above this, before paying
# PREDGE_MCP_USER_AGENT=predge-whale-data-mcp/0.1.1
